{
  "model_name": "hybrid_4_3_eg",
  "description": "Hybrid 4x3-Queue: 4 tandem stations, 3 fork-join branches, feedback p=0.5",
  "entities": {
    "Load": {
      "name": "Load",
      "parent": "Object",
      "attributes": {
        "arrival_time": "Real",
        "service_start_time_1": "Real",
        "service_start_time_2": "Real",
        "service_start_time_3": "Real",
        "service_start_time_4": "Real",
        "fork_time": "Real",
        "branch_start_time_1": "Real",
        "branch_start_time_2": "Real",
        "branch_start_time_3": "Real",
        "departure_time": "Real"
      }
    }
  },
  "parameters": {
    "service_capacity": {
      "type": "Nat",
      "value": 5,
      "description": "Number of servers per station"
    },
    "iat_mean": {
      "type": "Real",
      "value": 1.25,
      "description": "Inter-arrival time mean"
    },
    "ist_mean": {
      "type": "Real",
      "value": 1.0,
      "description": "Service time mean per station"
    },
    "feedback_prob": {
      "type": "Real",
      "value": 0.5,
      "description": "Probability of feedback to station 1"
    },
    "sim_end_time": {
      "type": "Real",
      "value": 10000.0,
      "description": "Simulation end time"
    }
  },
  "state_variables": {
    "queue_count_1": {
      "type": "Nat",
      "initial": 0,
      "description": "Number in queue at tandem station 1"
    },
    "server_count_1": {
      "type": "Nat",
      "initial": 0,
      "description": "Number being served at tandem station 1"
    },
    "queue_count_2": {
      "type": "Nat",
      "initial": 0,
      "description": "Number in queue at tandem station 2"
    },
    "server_count_2": {
      "type": "Nat",
      "initial": 0,
      "description": "Number being served at tandem station 2"
    },
    "queue_count_3": {
      "type": "Nat",
      "initial": 0,
      "description": "Number in queue at tandem station 3"
    },
    "server_count_3": {
      "type": "Nat",
      "initial": 0,
      "description": "Number being served at tandem station 3"
    },
    "queue_count_4": {
      "type": "Nat",
      "initial": 0,
      "description": "Number in queue at tandem station 4"
    },
    "server_count_4": {
      "type": "Nat",
      "initial": 0,
      "description": "Number being served at tandem station 4"
    },
    "branch_queue_1": {
      "type": "Nat",
      "initial": 0,
      "description": "Number in queue at branch 1"
    },
    "branch_server_1": {
      "type": "Nat",
      "initial": 0,
      "description": "Number being served at branch 1"
    },
    "part_1_num": {
      "type": "Nat",
      "initial": 0,
      "description": "Completed but not yet joined at branch 1"
    },
    "branch_queue_2": {
      "type": "Nat",
      "initial": 0,
      "description": "Number in queue at branch 2"
    },
    "branch_server_2": {
      "type": "Nat",
      "initial": 0,
      "description": "Number being served at branch 2"
    },
    "part_2_num": {
      "type": "Nat",
      "initial": 0,
      "description": "Completed but not yet joined at branch 2"
    },
    "branch_queue_3": {
      "type": "Nat",
      "initial": 0,
      "description": "Number in queue at branch 3"
    },
    "branch_server_3": {
      "type": "Nat",
      "initial": 0,
      "description": "Number being served at branch 3"
    },
    "part_3_num": {
      "type": "Nat",
      "initial": 0,
      "description": "Completed but not yet joined at branch 3"
    },
    "load_id_counter": {
      "type": "Nat",
      "initial": 0
    },
    "departure_count": {
      "type": "Nat",
      "initial": 0
    }
  },
  "random_streams": {
    "interarrival_time": {
      "distribution": "exponential",
      "params": {
        "mean": "iat_mean"
      },
      "stream_name": "arrivals"
    },
    "service_time_1": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_1"
    },
    "service_time_2": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_2"
    },
    "service_time_3": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_3"
    },
    "service_time_4": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_4"
    },
    "branch_service_time_1": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "branch_service_1"
    },
    "branch_service_time_2": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "branch_service_2"
    },
    "branch_service_time_3": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "branch_service_3"
    }
  },
  "vertices": [
    {
      "name": "Arrive",
      "description": "Customer arrival event",
      "state_change": "load_id_counter := load_id_counter + 1; queue_count_1 := queue_count_1 + 1"
    },
    {
      "name": "Start_1",
      "parameters": [
        {
          "load": "Load"
        }
      ],
      "description": "Service start at tandem station 1",
      "state_change": "queue_count_1 := queue_count_1 - 1; server_count_1 := server_count_1 + 1"
    },
    {
      "name": "Finish_1",
      "parameters": [
        {
          "load": "Load"
        }
      ],
      "description": "Service completion at tandem station 1",
      "state_change": "server_count_1 := server_count_1 - 1; queue_count_2 := queue_count_2 + 1"
    },
    {
      "name": "Start_2",
      "parameters": [
        {
          "load": "Load"
        }
      ],
      "description": "Service start at tandem station 2",
      "state_change": "queue_count_2 := queue_count_2 - 1; server_count_2 := server_count_2 + 1"
    },
    {
      "name": "Finish_2",
      "parameters": [
        {
          "load": "Load"
        }
      ],
      "description": "Service completion at tandem station 2",
      "state_change": "server_count_2 := server_count_2 - 1; queue_count_3 := queue_count_3 + 1"
    },
    {
      "name": "Start_3",
      "parameters": [
        {
          "load": "Load"
        }
      ],
      "description": "Service start at tandem station 3",
      "state_change": "queue_count_3 := queue_count_3 - 1; server_count_3 := server_count_3 + 1"
    },
    {
      "name": "Finish_3",
      "parameters": [
        {
          "load": "Load"
        }
      ],
      "description": "Service completion at tandem station 3",
      "state_change": "server_count_3 := server_count_3 - 1; queue_count_4 := queue_count_4 + 1"
    },
    {
      "name": "Start_4",
      "parameters": [
        {
          "load": "Load"
        }
      ],
      "description": "Service start at tandem station 4",
      "state_change": "queue_count_4 := queue_count_4 - 1; server_count_4 := server_count_4 + 1"
    },
    {
      "name": "Finish_4",
      "parameters": [
        {
          "load": "Load"
        }
      ],
      "description": "Service completion at tandem station 4",
      "state_change": "server_count_4 := server_count_4 - 1"
    },
    {
      "name": "Fork",
      "description": "Fork: distribute load to all branches",
      "state_change": "branch_queue_1 := branch_queue_1 + 1; branch_queue_2 := branch_queue_2 + 1; branch_queue_3 := branch_queue_3 + 1"
    },
    {
      "name": "Branch_Start_1",
      "parameters": [
        {
          "load": "Load"
        }
      ],
      "description": "Service start at branch 1",
      "state_change": "branch_queue_1 := branch_queue_1 - 1; branch_server_1 := branch_server_1 + 1"
    },
    {
      "name": "Branch_Finish_1",
      "parameters": [
        {
          "load": "Load"
        }
      ],
      "description": "Service completion at branch 1",
      "state_change": "branch_server_1 := branch_server_1 - 1; part_1_num := part_1_num + 1"
    },
    {
      "name": "Branch_Start_2",
      "parameters": [
        {
          "load": "Load"
        }
      ],
      "description": "Service start at branch 2",
      "state_change": "branch_queue_2 := branch_queue_2 - 1; branch_server_2 := branch_server_2 + 1"
    },
    {
      "name": "Branch_Finish_2",
      "parameters": [
        {
          "load": "Load"
        }
      ],
      "description": "Service completion at branch 2",
      "state_change": "branch_server_2 := branch_server_2 - 1; part_2_num := part_2_num + 1"
    },
    {
      "name": "Branch_Start_3",
      "parameters": [
        {
          "load": "Load"
        }
      ],
      "description": "Service start at branch 3",
      "state_change": "branch_queue_3 := branch_queue_3 - 1; branch_server_3 := branch_server_3 + 1"
    },
    {
      "name": "Branch_Finish_3",
      "parameters": [
        {
          "load": "Load"
        }
      ],
      "description": "Service completion at branch 3",
      "state_change": "branch_server_3 := branch_server_3 - 1; part_3_num := part_3_num + 1"
    },
    {
      "name": "Join",
      "description": "Join: synchronize all branches",
      "state_change": "part_1_num := part_1_num - 1; part_2_num := part_2_num - 1; part_3_num := part_3_num - 1"
    },
    {
      "name": "Attempt_To_Depart",
      "description": "Probabilistic departure/feedback decision",
      "state_change": ""
    },
    {
      "name": "Depart",
      "description": "Customer departs the system",
      "state_change": "departure_count := departure_count + 1"
    }
  ],
  "scheduling_edges": [
    {
      "from": "Arrive",
      "to": "Arrive",
      "delay": "interarrival_time",
      "condition": "true",
      "priority": 0
    },
    {
      "from": "Arrive",
      "to": "Start_1",
      "delay": 0,
      "condition": "server_count_1 < service_capacity",
      "priority": 0,
      "parameters": [
        "load"
      ]
    },
    {
      "from": "Start_1",
      "to": "Finish_1",
      "delay": "service_time_1",
      "condition": "true",
      "priority": 0,
      "parameters": [
        "load"
      ]
    },
    {
      "from": "Finish_1",
      "to": "Start_1",
      "delay": 0,
      "condition": "queue_count_1 > 0 and server_count_1 < service_capacity",
      "priority": 0,
      "parameters": [
        "next_load"
      ]
    },
    {
      "from": "Finish_1",
      "to": "Start_2",
      "delay": 0,
      "condition": "server_count_2 < service_capacity",
      "priority": 0,
      "parameters": [
        "load"
      ]
    },
    {
      "from": "Start_2",
      "to": "Finish_2",
      "delay": "service_time_2",
      "condition": "true",
      "priority": 0,
      "parameters": [
        "load"
      ]
    },
    {
      "from": "Finish_2",
      "to": "Start_2",
      "delay": 0,
      "condition": "queue_count_2 > 0 and server_count_2 < service_capacity",
      "priority": 0,
      "parameters": [
        "next_load"
      ]
    },
    {
      "from": "Finish_2",
      "to": "Start_3",
      "delay": 0,
      "condition": "server_count_3 < service_capacity",
      "priority": 0,
      "parameters": [
        "load"
      ]
    },
    {
      "from": "Start_3",
      "to": "Finish_3",
      "delay": "service_time_3",
      "condition": "true",
      "priority": 0,
      "parameters": [
        "load"
      ]
    },
    {
      "from": "Finish_3",
      "to": "Start_3",
      "delay": 0,
      "condition": "queue_count_3 > 0 and server_count_3 < service_capacity",
      "priority": 0,
      "parameters": [
        "next_load"
      ]
    },
    {
      "from": "Finish_3",
      "to": "Start_4",
      "delay": 0,
      "condition": "server_count_4 < service_capacity",
      "priority": 0,
      "parameters": [
        "load"
      ]
    },
    {
      "from": "Start_4",
      "to": "Finish_4",
      "delay": "service_time_4",
      "condition": "true",
      "priority": 0,
      "parameters": [
        "load"
      ]
    },
    {
      "from": "Finish_4",
      "to": "Start_4",
      "delay": 0,
      "condition": "queue_count_4 > 0 and server_count_4 < service_capacity",
      "priority": 0,
      "parameters": [
        "next_load"
      ]
    },
    {
      "from": "Finish_4",
      "to": "Fork",
      "delay": 0,
      "condition": "true",
      "priority": 0
    },
    {
      "from": "Fork",
      "to": "Branch_Start_1",
      "delay": 0,
      "condition": "branch_queue_1 > 0 and branch_server_1 < service_capacity",
      "priority": 0,
      "parameters": [
        "load"
      ]
    },
    {
      "from": "Fork",
      "to": "Branch_Start_2",
      "delay": 0,
      "condition": "branch_queue_2 > 0 and branch_server_2 < service_capacity",
      "priority": 0,
      "parameters": [
        "load"
      ]
    },
    {
      "from": "Fork",
      "to": "Branch_Start_3",
      "delay": 0,
      "condition": "branch_queue_3 > 0 and branch_server_3 < service_capacity",
      "priority": 0,
      "parameters": [
        "load"
      ]
    },
    {
      "from": "Branch_Start_1",
      "to": "Branch_Finish_1",
      "delay": "branch_service_time_1",
      "condition": "true",
      "priority": 0,
      "parameters": [
        "load"
      ]
    },
    {
      "from": "Branch_Finish_1",
      "to": "Branch_Start_1",
      "delay": 0,
      "condition": "branch_queue_1 > 0 and branch_server_1 < service_capacity",
      "priority": 0,
      "parameters": [
        "next_load"
      ]
    },
    {
      "from": "Branch_Finish_1",
      "to": "Join",
      "delay": 0,
      "condition": "true",
      "priority": 0
    },
    {
      "from": "Branch_Start_2",
      "to": "Branch_Finish_2",
      "delay": "branch_service_time_2",
      "condition": "true",
      "priority": 0,
      "parameters": [
        "load"
      ]
    },
    {
      "from": "Branch_Finish_2",
      "to": "Branch_Start_2",
      "delay": 0,
      "condition": "branch_queue_2 > 0 and branch_server_2 < service_capacity",
      "priority": 0,
      "parameters": [
        "next_load"
      ]
    },
    {
      "from": "Branch_Finish_2",
      "to": "Join",
      "delay": 0,
      "condition": "true",
      "priority": 0
    },
    {
      "from": "Branch_Start_3",
      "to": "Branch_Finish_3",
      "delay": "branch_service_time_3",
      "condition": "true",
      "priority": 0,
      "parameters": [
        "load"
      ]
    },
    {
      "from": "Branch_Finish_3",
      "to": "Branch_Start_3",
      "delay": 0,
      "condition": "branch_queue_3 > 0 and branch_server_3 < service_capacity",
      "priority": 0,
      "parameters": [
        "next_load"
      ]
    },
    {
      "from": "Branch_Finish_3",
      "to": "Join",
      "delay": 0,
      "condition": "true",
      "priority": 0
    },
    {
      "from": "Join",
      "to": "Attempt_To_Depart",
      "delay": 0,
      "condition": "part_1_num > 0 and part_2_num > 0 and part_3_num > 0",
      "priority": 0
    },
    {
      "from": "Attempt_To_Depart",
      "to": "Start_1",
      "delay": 0,
      "condition": "feedback",
      "priority": 0,
      "feedback_action": "queue_count_1 := queue_count_1 + 1"
    },
    {
      "from": "Attempt_To_Depart",
      "to": "Depart",
      "delay": 0,
      "condition": "not_feedback",
      "priority": 0,
      "depart_action": "departure_count := departure_count + 1"
    }
  ],
  "cancelling_edges": [],
  "initial_events": [
    {
      "event": "Arrive",
      "time": "interarrival_time"
    }
  ],
  "stopping_condition": "sim_clocktime >= sim_end_time",
  "observables": {
    "queue_count_1": {
      "name": "queue_count_1",
      "expression": "queue_count_1",
      "description": "Number in queue at tandem station 1"
    },
    "server_count_1": {
      "name": "server_count_1",
      "expression": "server_count_1",
      "description": "Number of busy servers at tandem station 1"
    },
    "queue_count_2": {
      "name": "queue_count_2",
      "expression": "queue_count_2",
      "description": "Number in queue at tandem station 2"
    },
    "server_count_2": {
      "name": "server_count_2",
      "expression": "server_count_2",
      "description": "Number of busy servers at tandem station 2"
    },
    "queue_count_3": {
      "name": "queue_count_3",
      "expression": "queue_count_3",
      "description": "Number in queue at tandem station 3"
    },
    "server_count_3": {
      "name": "server_count_3",
      "expression": "server_count_3",
      "description": "Number of busy servers at tandem station 3"
    },
    "queue_count_4": {
      "name": "queue_count_4",
      "expression": "queue_count_4",
      "description": "Number in queue at tandem station 4"
    },
    "server_count_4": {
      "name": "server_count_4",
      "expression": "server_count_4",
      "description": "Number of busy servers at tandem station 4"
    },
    "branch_queue_1": {
      "name": "branch_queue_1",
      "expression": "branch_queue_1",
      "description": "Number in queue at branch 1"
    },
    "branch_server_1": {
      "name": "branch_server_1",
      "expression": "branch_server_1",
      "description": "Number of busy servers at branch 1"
    },
    "branch_queue_2": {
      "name": "branch_queue_2",
      "expression": "branch_queue_2",
      "description": "Number in queue at branch 2"
    },
    "branch_server_2": {
      "name": "branch_server_2",
      "expression": "branch_server_2",
      "description": "Number of busy servers at branch 2"
    },
    "branch_queue_3": {
      "name": "branch_queue_3",
      "expression": "branch_queue_3",
      "description": "Number in queue at branch 3"
    },
    "branch_server_3": {
      "name": "branch_server_3",
      "expression": "branch_server_3",
      "description": "Number of busy servers at branch 3"
    },
    "in_system": {
      "name": "in_system",
      "expression": "queue_count_1 + server_count_1 + queue_count_2 + server_count_2 + queue_count_3 + server_count_3 + queue_count_4 + server_count_4 + branch_queue_1 + branch_server_1 + part_1_num + branch_queue_2 + branch_server_2 + part_2_num + branch_queue_3 + branch_server_3 + part_3_num",
      "description": "Total in system"
    },
    "L_q_total": {
      "name": "L_q_total",
      "expression": "queue_count_1 + queue_count_2 + queue_count_3 + queue_count_4 + branch_queue_1 + branch_queue_2 + branch_queue_3",
      "description": "Total queue length"
    },
    "departure_count": {
      "name": "departure_count",
      "expression": "departure_count",
      "description": "Total departures"
    }
  },
  "statistics": [
    {
      "name": "L_q_total",
      "type": "time_average",
      "observable": "L_q_total",
      "description": "Average total queue length"
    },
    {
      "name": "L",
      "type": "time_average",
      "observable": "in_system",
      "description": "Average number in system"
    },
    {
      "name": "throughput",
      "type": "count",
      "observable": "departure_count",
      "description": "Total departures"
    }
  ]
}